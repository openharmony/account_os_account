{
    "name": "ohos-acm",
    "version": "1.0.0",
    "description": "ohos-acm - OS Account management command-line utility for querying OS account information.",
    "executablePath": "/system/bin/cli_tool/executable/ohos-acm",
    "requirePermissions": [],
    "inputSchema": {
        "type": "object",
