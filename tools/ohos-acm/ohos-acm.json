                        "enum": ["success", "failed"]
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "userId": {
                                "type": "integer",
                                "description": "Local ID of the current OS account"
                            }
                        },
                        "required": ["userId"]
                    },
                    "errCode": {
                        "type": "string"
                    },
                    "errMsg": {
                        "type": "string"
                    },
                    "suggestion": {
