ohos_unittest("app_account_subspace_coverage_test") {
  branch_protector_ret = "pac_ret"

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }

  module_out_path = module_output_path
  cflags_cc = [ "-DENABLE_MULTIPLE_OS_ACCOUNT_SUBSPACE" ]
  cflags = []

  sources = [
    "${app_account_services_path}/src/ability_manager_adapter/ability_manager_adapter.cpp",
    "${app_account_services_path}/src/appaccount/app_account_control_manager.cpp",
    "${app_account_services_path}/src/appaccount/app_account_manager_service.cpp",
    "${app_account_services_path}/src/appaccount/inner_app_account_manager.cpp",
    "${app_account_services_path}/src/bundle_manager_adapter/bundle_manager_adapter_proxy.cpp",
    "${app_account_services_path}/src/bundle_manager_adapter/bundle_user_manager_adapter_proxy.cpp",
    "${app_account_services_path}/test/mock/app_account/account_data_storage.cpp",
    "${app_account_services_path}/test/mock/common/bundle_manager_adapter.cpp",
    "${os_account_core_path}/src/os_account_state_parcel.cpp",
    "${services_path}/accountmgr/src/appaccount/os_account_state_subscriber.cpp",
    "${services_path}/accountmgr/src/osaccount/os_account_state_reply_callback_service.cpp",
    "${services_path}/accountmgr/src/osaccount/os_account_subscribe_death_recipient.cpp",
    "${services_path}/accountmgr/src/osaccount/os_account_subscribe_manager.cpp",
    "${services_path}/accountmgr/src/common/database/kvstore/kvstore_adapter_impl.cpp",
    "app_account_subspace_coverage_test.cpp",
  ]

  sources += app_account_sources_mock
  use_exceptions = true

  include_dirs = [
    "${app_account_services_path}/test/mock/app_account",
    "${app_account_services_path}/test/mock/common",
    "${app_account_innerkits_native_path}/include",
    "${services_path}/accountmgr/include/common/database/kvstore",
    "${services_path}/accountmgr/include/common/database",
    "${os_account_dfx_path}/hisysevent_adapter",
  ]

  configs = [
    ":app_account_service_config_unittest",
    "${app_account_services_path}/test/mock:mock_accountmgr_config",
    "${app_account_services_path}/test/mock:accountmgr_config",
  ]

  deps = [
    "${app_account_innerkits_native_path}:app_account_innerkits",
    "${common_path}:libaccount_common",
    "${os_account_innerkits_native_path}:os_account_event_stub",
    "${os_account_innerkits_native_path}:os_account_innerkits",
    "${os_account_innerkits_native_path}:os_account_state_reply_callback_stub",
  ]

  deps += [ "${app_account_innerkits_native_path}:app_account_stub" ]

  external_deps = [
    "ability_base:base",
    "ability_base:configuration",
    "ability_base:want",
    "ability_runtime:ability_connect_callback_stub",
    "ability_runtime:app_manager",
    "access_token:libaccesstoken_sdk",
    "access_token:libtokensetproc_shared",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "cJSON:cjson",
    "c_utils:utils",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_single",
    "kv_store:distributeddata_inner",
    "openssl:libcrypto_shared",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
  ]

  external_deps += [
    "ability_runtime:wantagent_innerkits",
    "access_token:libtokenid_sdk",
  ]

  if (has_hiviewdfx_hisysevent_part) {
    external_deps += [ "hisysevent:libhisysevent" ]
  }
  if (has_hiviewdfx_hitrace_part) {
    external_deps += [ "hitrace:hitrace_meter" ]
  }
  if (has_ces_part) {
    cflags_cc += [ "-DHAS_CES_PART" ]
    external_deps += [ "common_event_service:cesfwk_innerkits" ]
  }
  if (has_asset_part) {
    external_deps += [ "asset:asset_sdk" ]
    cflags_cc += [ "-DHAS_ASSET_PART" ]
  }
  if (has_kv_store_part) {
    external_deps += [ "kv_store:distributeddata_inner" ]
  }
  if (hicollie_enable == true) {
    external_deps += [ "hicollie:libhicollie" ]
  }
  if (security_guard_enabled) {
    external_deps += [
      "security_guard:libsg_collect_sdk",
      "time_service:time_client",
    ]
  }
  if (has_user_auth_part) {
    external_deps += [
      "access_token:libtoken_setproc",
      "user_auth_framework:userauth_client",
    ]
  }
  if (has_huks_part) {
    external_deps += [ "huks:libhukssdk" ]
  }
  if (os_account_distributed_feature) {
    cflags += [ "-DDISTRIBUTED_FEATURE_ENABLED" ]
  }
}

