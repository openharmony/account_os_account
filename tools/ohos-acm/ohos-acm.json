            "inputSchema": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    }
                }
            },
            "outputSchema": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["result"]
                    },
                    "status": {
