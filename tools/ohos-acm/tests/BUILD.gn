import("//build/test.gni")
import("../../../os_account.gni")

module_output_path = "os_account/os_account"

ohos_unittest("ohos_acm_test") {
  branch_protector_ret = "pac_ret"

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
  }

  module_out_path = module_output_path

  sources = [
    "../src/commands.cpp",
    "ohos_acm_test.cpp",
  ]

  include_dirs = [
    "../include",
    "${os_account_interfaces_native_path}/include",
    "${innerkits_common}/include",
    "${common_path}/json_utils/include",
  ]

  cflags = []
  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }

  deps = [
    "${os_account_innerkits_native_path}:os_account_innerkits",
    "${common_path}:libaccount_common",
  ]

  external_deps = [
    "c_utils:utils",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_single",
    "cJSON:cjson",
    "samgr:samgr_proxy",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":ohos_acm_test" ]
}
